{
  "hosting": [{
    "target": "companion-login",
    "public": "login",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
{
      "target": "companion-typing",
